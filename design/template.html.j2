<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Kavach — an independent robustness benchmark for LLM guardrails</title>
<meta name="description" content="Prompt-injection detectors, scored honestly: detection rate and over-defense on English attacks, then on the same attacks code-switched into Tamil-English.">
<meta name="theme-color" content="#191512">
<link rel="icon" href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24'%3E%3Crect width='24' height='24' rx='5' fill='%23191512'/%3E%3Cpath d='M12 4 6 6.2v4.3c0 3.6 2.5 6.1 6 7.8 3.5-1.7 6-4.2 6-7.8V6.2L12 4Z' fill='none' stroke='%23E8B15A' stroke-width='1.6' stroke-linejoin='round'/%3E%3C/svg%3E">
<meta property="og:type" content="website">
<meta property="og:title" content="Kavach — how well do LLM guardrails actually hold up?">
<meta property="og:description" content="An independent benchmark. Code-switching attacks into Tamil-English didn't help them evade — but over-defense on ordinary bilingual messages nearly doubled.">
<meta property="og:image" content="og.png">
<meta name="twitter:card" content="summary_large_image">
<meta name="twitter:title" content="Kavach — how well do LLM guardrails actually hold up?">
<meta name="twitter:description" content="An independent benchmark. Code-switching didn't help attacks evade — but over-defense on ordinary bilingual messages nearly doubled.">
<meta name="twitter:image" content="og.png">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Chivo:wght@400;500;700&family=Instrument+Serif:ital@0;1&family=Spline+Sans+Mono:wght@400;500;600&display=swap" rel="stylesheet">
<style>
  :root{
    --ground:#191512;
    --panel:#221D19;
    --panel-2:#2A241F;
    --paper:#F0EBE3;
    --muted:#A2968A;
    --faint:#6E635A;
    --rule:rgba(240,235,227,0.10);
    --rule-strong:rgba(240,235,227,0.20);
    --block:#FF5436;      /* semantic: wrongly blocked / notable regression */
    --allow:#8FB98A;      /* semantic: correctly allowed */
    --accent:#E8B15A;     /* interactive: buttons, links, focus — never a verdict */
    --accent-ink:#1A130A; /* text on an accent fill */
    --accent-soft:rgba(232,177,90,0.12);
    --display:'Instrument Serif',Georgia,serif;
    --body:'Chivo',system-ui,sans-serif;
    --data:'Spline Sans Mono',ui-monospace,monospace;

    /* width — one wide column; prose is capped by measure, not by the wrap */
    --maxw-wide:1240px;
    --measure:68ch;

    /* radius + elevation — material system for cards and controls */
    --r-sm:6px;
    --r-md:8px;
    --bevel:inset 0 1px 0 rgba(240,235,227,0.06);
    --shadow-card:0 1px 2px rgba(0,0,0,0.3), 0 14px 34px -18px rgba(0,0,0,0.62);
    --shadow-lift:0 2px 4px rgba(0,0,0,0.32), 0 22px 48px -20px rgba(0,0,0,0.7);

    /* spacing scale — the ONLY margin/padding values used anywhere */
    --s1:8px;
    --s2:16px;
    --s3:24px;
    --s4:40px;
    --s5:64px;
    --s6:80px;
    --s7:104px;

    /* type scale — the ONLY six font sizes used anywhere */
    --t-eyebrow:12px;
    --t-small:13px;
    --t-body:17.5px;
    --t-lead:20px;
    --t-h2:clamp(26px,3vw,32px);
    --t-h1:clamp(40px,6.2vw,68px);
  }
  *{box-sizing:border-box;margin:0;padding:0}
  html{scroll-behavior:smooth}
  body{background:var(--ground);color:var(--paper);font-family:var(--body);font-size:var(--t-body);line-height:1.65;-webkit-font-smoothing:antialiased}
  /* every section shares this wrap → one left edge */
  .wrap{max-width:var(--maxw-wide);margin:0 auto;padding:0 var(--s3)}
  a{color:inherit}
  :focus-visible{outline:2px solid var(--accent);outline-offset:3px}

  .tag{font-family:var(--data);font-size:var(--t-eyebrow);letter-spacing:0.16em;text-transform:uppercase;color:var(--muted)}

  nav{border-bottom:1px solid var(--rule);position:sticky;top:0;background:rgba(25,21,18,0.9);backdrop-filter:blur(10px);z-index:20}
  .nav-in{max-width:var(--maxw-wide);margin:0 auto;padding:var(--s2) var(--s3);display:flex;justify-content:space-between;align-items:center}
  .brand{font-family:var(--display);font-size:var(--t-lead);letter-spacing:0.01em;text-decoration:none}
  .nav-l{display:flex;gap:var(--s3);font-family:var(--data);font-size:var(--t-eyebrow);color:var(--muted)}
  .nav-l a{text-decoration:none}
  .nav-l a:hover{color:var(--paper)}
  @media(max-width:600px){.nav-l a.sm{display:none}}

  header{padding:var(--s6) 0 0;position:relative;overflow:hidden}
  header::before{
    content:"";position:absolute;top:-140px;left:50%;transform:translateX(-58%);
    width:900px;height:520px;pointer-events:none;z-index:0;
    background:radial-gradient(closest-side,rgba(232,177,90,0.14),rgba(232,177,90,0.05) 55%,transparent 75%);
  }
  header .wrap{position:relative;z-index:1}
  h1{
    font-family:var(--display);font-weight:400;
    font-size:var(--t-h1);line-height:1.04;letter-spacing:-0.015em;
    max-width:21ch;margin-top:var(--s3);
  }
  h1 i{font-style:italic;color:var(--block)}
  .sub{margin-top:var(--s3);max-width:52ch;color:var(--muted);font-size:var(--t-lead);line-height:1.5}
  .sub b{color:var(--paper);font-weight:500}

  /* ---- SIGNATURE: the message log ---- */
  .log{margin-top:var(--s4);border:1px solid var(--rule-strong);border-radius:var(--r-md);background:linear-gradient(180deg,var(--panel-2),var(--panel));overflow:hidden;box-shadow:var(--bevel),var(--shadow-card)}
  .log-bar{
    display:flex;justify-content:space-between;align-items:center;gap:var(--s2);flex-wrap:wrap;
    padding:var(--s2) var(--s3);border-bottom:1px solid var(--rule);background:var(--panel-2);
    font-family:var(--data);font-size:var(--t-small);color:var(--muted);letter-spacing:0.04em;
  }
  .seg{display:inline-flex;border:1px solid var(--rule-strong);border-radius:3px;overflow:hidden}
  .seg button{
    font-family:var(--data);font-size:var(--t-small);letter-spacing:0.06em;padding:var(--s1) var(--s2);
    border:0;background:transparent;color:var(--muted);cursor:pointer;transition:background .18s,color .18s;
  }
  .seg button[aria-pressed="true"]{background:var(--paper);color:var(--ground);font-weight:600}

  /* messages as an intercepted chat: human text in the body face,
     the detector's verdict as a receipt tag in mono */
  .msg{display:flex;gap:var(--s2);align-items:flex-start;padding:var(--s3);border-bottom:1px solid var(--rule)}
  .msg:last-child{border-bottom:0}
  .msg-av{flex:none;width:34px;height:34px;border-radius:999px;display:grid;place-items:center;background:radial-gradient(120% 120% at 30% 20%,#3A322B,#241F1B);border:1px solid var(--rule-strong);color:var(--muted);transition:border-color .3s ease,color .3s ease}
  .msg-av svg{width:17px;height:17px}
  .msg-body{flex:1;min-width:0;display:flex;flex-direction:column;align-items:flex-start;gap:var(--s1)}
  .msg-bubble{max-width:100%;font-family:var(--body);font-size:var(--t-body);line-height:1.5;color:var(--paper);background:var(--panel-2);border:1px solid var(--rule);border-radius:4px 15px 15px 15px;padding:var(--s2) var(--s3);transition:background .3s ease,border-color .3s ease}
  .verdict{display:inline-flex;align-items:center;gap:6px;font-family:var(--data);font-size:var(--t-eyebrow);font-weight:600;letter-spacing:0.1em;padding:4px 10px;border-radius:999px;white-space:nowrap;transition:all .3s ease}
  .verdict svg{width:12px;height:12px;flex:none}
  .msg[data-v="allow"] .verdict{color:var(--allow);box-shadow:inset 0 0 0 1px rgba(143,185,138,0.42)}
  .msg[data-v="block"] .verdict{background:var(--block);color:#1A0A06}
  .msg[data-v="block"] .msg-bubble{background:rgba(255,84,54,0.07);border-color:rgba(255,84,54,0.38)}
  .msg[data-v="block"] .msg-av{border-color:rgba(255,84,54,0.38);color:var(--block)}
  .log-foot{padding:var(--s2) var(--s3);font-family:var(--data);font-size:var(--t-small);color:var(--faint);background:var(--panel-2);border-top:1px solid var(--rule)}

  /* stat strip → metric cards */
  .strip{margin-top:var(--s5);display:grid;grid-template-columns:repeat(3,1fr);gap:var(--s3)}
  @media(max-width:760px){.strip{grid-template-columns:1fr}}
  .stat{padding:var(--s3);border:1px solid var(--rule-strong);border-radius:var(--r-md);background:linear-gradient(180deg,var(--panel-2),var(--panel));box-shadow:var(--bevel),var(--shadow-card);transition:transform .2s ease,box-shadow .2s ease}
  .stat:hover{transform:translateY(-2px);box-shadow:var(--bevel),var(--shadow-lift)}
  .stat-top{display:flex;justify-content:space-between;align-items:center;gap:var(--s2)}
  .stat .k{font-family:var(--data);font-size:var(--t-eyebrow);letter-spacing:0.1em;text-transform:uppercase;color:var(--muted)}
  .stat .v{font-family:var(--display);font-size:var(--t-h1);line-height:1;margin-top:var(--s3);letter-spacing:-0.01em}
  .stat .v.bad{color:var(--block)}
  .stat .c{margin-top:var(--s2);font-size:var(--t-small);color:var(--muted);max-width:34ch}
  /* meter: 0→100% fill with an optional baseline tick */
  .meter{margin-top:var(--s3);height:6px;border-radius:999px;background:rgba(240,235,227,0.08);position:relative;overflow:hidden}
  .meter>i{position:absolute;inset:0 auto 0 0;border-radius:999px;background:var(--muted);width:0;transition:width .9s cubic-bezier(.2,.7,.2,1)}
  .meter.bad>i{background:var(--block)}
  .meter>b{position:absolute;top:0;bottom:0;width:2px;background:var(--paper);opacity:.55}
  .chip{display:inline-flex;align-items:center;gap:6px;font-family:var(--data);font-size:var(--t-eyebrow);letter-spacing:0.04em;padding:5px 10px;border-radius:999px;border:1px solid var(--rule-strong);color:var(--muted);white-space:nowrap}
  .chip.bad{color:var(--block);border-color:rgba(255,84,54,0.42);background:rgba(255,84,54,0.08)}
  .chip.ok{color:var(--allow);border-color:rgba(143,185,138,0.42);background:rgba(143,185,138,0.08)}

  /* ---- interactive chrome: brand mark, buttons, pill, CTA ---- */
  .brand{display:inline-flex;align-items:center;gap:var(--s1)}
  .brand svg{width:20px;height:20px;color:var(--accent)}
  .nav-r{display:flex;align-items:center;gap:var(--s3)}
  .btn{display:inline-flex;align-items:center;gap:var(--s1);font-family:var(--data);font-size:var(--t-small);letter-spacing:0.02em;padding:var(--s1) var(--s3);border-radius:var(--r-sm);border:1px solid var(--rule-strong);color:var(--paper);text-decoration:none;background:transparent;cursor:pointer;transition:transform .16s ease,background .16s ease,border-color .16s ease,box-shadow .16s ease}
  .btn:hover{transform:translateY(-1px);border-color:rgba(240,235,227,0.35)}
  .btn svg{width:15px;height:15px;flex:none}
  .btn.primary{background:var(--accent);color:var(--accent-ink);border-color:var(--accent);font-weight:600}
  .btn.primary:hover{background:#F0C070;box-shadow:var(--shadow-card)}
  .btn.sm{padding:var(--s1) var(--s2);font-size:var(--t-eyebrow)}
  @media(max-width:600px){.btn .btn-t{display:none}.btn.sm{padding:var(--s1)}}
  .pill{display:inline-flex;align-items:center;gap:var(--s1);font-family:var(--data);font-size:var(--t-eyebrow);letter-spacing:0.1em;text-transform:uppercase;color:var(--muted);padding:6px 12px;border:1px solid var(--rule-strong);border-radius:999px;background:rgba(0,0,0,0.16)}
  .pill i{width:7px;height:7px;border-radius:999px;background:var(--accent);box-shadow:0 0 0 3px var(--accent-soft)}
  .cta{display:flex;gap:var(--s2);flex-wrap:wrap;margin-top:var(--s4)}

  /* segmented control with sliding indicator (JS positions .seg-ind) */
  .seg{position:relative;display:inline-flex;border:1px solid var(--rule-strong);border-radius:var(--r-sm);background:rgba(0,0,0,0.18)}
  .seg .seg-ind{position:absolute;top:2px;bottom:2px;left:0;width:0;border-radius:calc(var(--r-sm) - 2px);background:var(--paper);box-shadow:0 1px 2px rgba(0,0,0,0.35);transition:left .28s cubic-bezier(.2,.7,.2,1),width .28s cubic-bezier(.2,.7,.2,1);z-index:0}
  .seg button{position:relative;z-index:1;font-family:var(--data);font-size:var(--t-small);letter-spacing:0.05em;padding:var(--s1) var(--s2);border:0;background:transparent;color:var(--muted);cursor:pointer;transition:color .22s ease;white-space:nowrap}
  .seg button[aria-pressed="true"]{color:var(--ground);font-weight:600}
  .seg:not(.seg--js) button[aria-pressed="true"]{background:var(--paper);border-radius:calc(var(--r-sm) - 2px)}

  section{padding:var(--s7) 0 0}
  h2{font-family:var(--display);font-size:var(--t-h2);font-weight:400;letter-spacing:-0.01em}
  .kicker{font-family:var(--data);font-size:var(--t-eyebrow);letter-spacing:0.14em;text-transform:uppercase;color:var(--muted);margin-bottom:var(--s2)}
  .kicker b{color:var(--accent);font-weight:500}
  .sec-head{display:flex;justify-content:space-between;align-items:baseline;gap:var(--s2);flex-wrap:wrap;margin-bottom:var(--s4)}
  .sec-sub{max-width:60ch;color:var(--muted);font-size:var(--t-body);margin:calc(var(--s4) * -1 + var(--s1)) 0 var(--s4)}

  /* ---- reveal-on-scroll ---- */
  .reveal{opacity:0;transform:translateY(14px);transition:opacity .6s ease,transform .6s cubic-bezier(.2,.7,.2,1)}
  .reveal.in{opacity:1;transform:none}
  .strip .stat.reveal:nth-child(2){transition-delay:.08s}
  .strip .stat.reveal:nth-child(3){transition-delay:.16s}
  @media(prefers-reduced-motion:reduce){.reveal{opacity:1;transform:none;transition:none}}

  /* ---- EXPLORER ---- */
  .xp-bar{display:flex;flex-wrap:wrap;align-items:flex-end;gap:var(--s3);margin-bottom:var(--s3)}
  .xp-f{display:flex;flex-direction:column;gap:var(--s1)}
  .xp-f-lab{font-family:var(--data);font-size:var(--t-eyebrow);letter-spacing:0.1em;text-transform:uppercase;color:var(--faint)}
  .xp-count{margin-left:auto;font-family:var(--data);font-size:var(--t-small);color:var(--muted);align-self:flex-end}
  .xp-count b{color:var(--paper)}
  .xp-main{display:grid;grid-template-columns:340px 1fr;gap:var(--s3);align-items:start}
  @media(max-width:820px){
    .xp-main{grid-template-columns:1fr}
    .xp-bar .xp-f{width:100%}
    .xp-bar .seg{width:100%}
    .xp-bar .seg button{flex:1}
    .xp-count{margin-left:0}
  }

  .xp-list{border:1px solid var(--rule-strong);border-radius:var(--r-md);background:linear-gradient(180deg,var(--panel-2),var(--panel));box-shadow:var(--bevel),var(--shadow-card);max-height:560px;overflow-y:auto}
  @media(max-width:820px){.xp-list{max-height:320px}}
  .xp-item{display:grid;grid-template-columns:auto 1fr auto;gap:var(--s2);align-items:center;padding:var(--s2) var(--s3);border-bottom:1px solid var(--rule);cursor:pointer;transition:background .14s ease}
  .xp-item:last-child{border-bottom:0}
  .xp-item:hover{background:rgba(240,235,227,0.035)}
  .xp-item.sel{background:var(--accent-soft);box-shadow:inset 3px 0 0 var(--accent)}
  .xp-dots{display:inline-flex;gap:5px}
  .dot{width:8px;height:8px;border-radius:999px;background:var(--faint)}
  .dot.block{background:var(--block)}
  .dot.allow{background:var(--allow);opacity:.75}
  .dot.mute{opacity:.28}
  .xp-snip{font-family:var(--data);font-size:var(--t-small);color:var(--muted);white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
  .xp-item.sel .xp-snip{color:var(--paper)}
  .xp-flip{font-family:var(--data);font-size:var(--t-eyebrow);color:var(--accent);white-space:nowrap}
  .xp-empty{padding:var(--s4) var(--s3);font-family:var(--data);font-size:var(--t-small);color:var(--faint);text-align:center}

  .xp-detail{border:1px solid var(--rule-strong);border-radius:var(--r-md);background:linear-gradient(180deg,var(--panel-2),var(--panel));box-shadow:var(--bevel),var(--shadow-card);padding:var(--s3)}
  .xp-d-top{display:flex;justify-content:space-between;align-items:center;gap:var(--s2);flex-wrap:wrap;margin-bottom:var(--s3)}
  .xp-d-meta{display:flex;align-items:center;gap:var(--s2);flex-wrap:wrap;min-width:0}
  .badge{font-family:var(--data);font-size:var(--t-eyebrow);letter-spacing:0.08em;text-transform:uppercase;padding:3px 9px;border-radius:var(--r-sm);border:1px solid var(--rule-strong);color:var(--muted);white-space:nowrap}
  .badge.attack{color:var(--paper);border-color:rgba(240,235,227,0.28)}
  .xp-d-id{font-family:var(--data);font-size:var(--t-eyebrow);color:var(--faint);overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
  .xp-d-text{font-family:var(--data);font-size:var(--t-small);line-height:1.6;color:var(--paper);white-space:pre-wrap;word-break:break-word;background:rgba(0,0,0,0.2);border:1px solid var(--rule);border-radius:var(--r-sm);padding:var(--s2);max-height:230px;overflow:auto;transition:opacity .2s ease}
  .xp-verdicts{margin-top:var(--s3)}
  .xp-v{padding:var(--s3) 0;border-top:1px solid var(--rule)}
  .xp-v:first-child{border-top:0}
  .xp-v-head{display:flex;align-items:center;gap:var(--s2)}
  .xp-v-name{font-family:var(--data);font-size:var(--t-small);color:var(--paper)}
  .xp-v-flip{font-family:var(--data);font-size:var(--t-eyebrow);letter-spacing:0.04em;color:var(--accent)}
  .xp-v-score{margin-left:auto;font-family:var(--data);font-size:var(--t-small);color:var(--muted);font-variant-numeric:tabular-nums}
  .stamp{font-family:var(--data);font-size:var(--t-eyebrow);font-weight:600;letter-spacing:0.12em;padding:var(--s1) var(--s2);border-radius:var(--r-sm);white-space:nowrap;transition:all .3s ease}
  .stamp.block{background:var(--block);color:#1A0A06}
  .stamp.allow{background:transparent;color:var(--allow);box-shadow:inset 0 0 0 1px rgba(143,185,138,0.42)}
  .xp-v-meter{margin-top:var(--s2)}
  .thr{position:absolute;top:-2px;bottom:-2px;left:50%;width:1px;background:var(--faint)}

  /* ---- footer ---- */

  .tbl{border:1px solid var(--rule-strong);border-radius:var(--r-md);overflow-x:auto;background:linear-gradient(180deg,var(--panel-2),var(--panel));box-shadow:var(--bevel),var(--shadow-card)}
  tbody tr{transition:background .18s ease}
  tbody tr:hover{background:rgba(240,235,227,0.03)}
  table{width:100%;border-collapse:collapse;font-size:var(--t-body);min-width:1000px}
  th{font-family:var(--data);font-size:var(--t-eyebrow);letter-spacing:0.1em;text-transform:uppercase;color:var(--muted);font-weight:500;text-align:right;padding:var(--s2);border-bottom:1px solid var(--rule-strong)}
  th:first-child{text-align:left}
  td{padding:var(--s2);text-align:right;font-family:var(--data);font-variant-numeric:tabular-nums;border-bottom:1px solid var(--rule)}
  tr:last-child td{border-bottom:0}
  td.d{text-align:left;font-family:var(--body);font-weight:500}
  .bad{color:var(--block);font-weight:600}
  .ok{color:var(--allow)}
  .dim{color:var(--muted)}
  .ci{display:block;font-size:var(--t-eyebrow);color:var(--faint);margin-top:var(--s1)}
  .tbl-foot{padding:var(--s2);font-family:var(--data);font-size:var(--t-small);color:var(--faint);border-top:1px solid var(--rule)}

  /* narrative prose — left-aligned block, capped by measure (no auto margin) */
  .prose{max-width:var(--measure)}
  .prose p{color:var(--muted);font-size:var(--t-body);line-height:1.65;margin-top:var(--s3)}
  .prose p:first-child{margin-top:0}
  .prose strong{color:var(--paper);font-weight:500}
  .prose code{font-family:var(--data);font-size:0.9em;color:var(--paper)}
  p.pull{font-family:var(--display);font-size:var(--t-h2);line-height:1.28;color:var(--paper);margin:var(--s4) 0;max-width:22ch}

  /* method / limits — two-column spec sheet, same left edge as everything */
  .spec{max-width:920px}
  .spec-row{display:grid;grid-template-columns:180px 1fr;gap:var(--s4);padding:var(--s3) 0;border-top:1px solid var(--rule);align-items:start}
  .spec-row:first-child{border-top:0;padding-top:0}
  .spec-term{font-family:var(--data);font-size:var(--t-small);color:var(--paper);font-weight:500;letter-spacing:0.01em}
  .spec-def{font-family:var(--body);font-size:var(--t-body);line-height:1.65;color:var(--muted)}
  .spec-def code{font-family:var(--data);font-size:0.9em;color:var(--paper)}
  .spec-def a{color:var(--paper);text-decoration:underline;text-decoration-color:var(--faint);text-underline-offset:2px}
  @media(max-width:640px){.spec-row{grid-template-columns:1fr;gap:var(--s1)}}

  footer{margin-top:var(--s7);border-top:1px solid var(--rule);padding:var(--s5) 0}
  .foot-cols{display:grid;grid-template-columns:2fr 1fr 1fr 1fr;gap:var(--s4)}
  @media(max-width:760px){.foot-cols{grid-template-columns:1fr 1fr}}
  @media(max-width:460px){.foot-cols{grid-template-columns:1fr}}
  .foot-brand .brand{font-family:var(--display);font-size:var(--t-lead)}
  .foot-tag{margin-top:var(--s2);max-width:34ch;font-family:var(--body);font-size:var(--t-small);color:var(--muted);line-height:1.6}
  .foot-col h4{font-family:var(--data);font-size:var(--t-eyebrow);letter-spacing:0.1em;text-transform:uppercase;color:var(--muted);margin-bottom:var(--s2)}
  .foot-col a{display:block;font-family:var(--body);font-size:var(--t-small);color:var(--muted);text-decoration:none;padding:5px 0}
  .foot-col a:hover{color:var(--paper)}
  .foot-bot{margin-top:var(--s5);padding-top:var(--s3);border-top:1px solid var(--rule);display:flex;justify-content:space-between;gap:var(--s3);flex-wrap:wrap;font-family:var(--data);font-size:var(--t-eyebrow);color:var(--faint)}
  .foot-bot a{text-decoration:none}
  .foot-bot a:hover{color:var(--muted)}

  @media(max-width:760px){
    section{padding-top:var(--s6)}
    header{padding-top:var(--s5)}
  }
  @media(prefers-reduced-motion:reduce){*{transition:none!important}html{scroll-behavior:auto}}
</style>
</head>
<body>

<a id="top"></a>
<nav>
  <div class="nav-in">
    <a class="brand" href="#top" aria-label="Kavach — home">
      <svg viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M12 2 4 5v6c0 5 3.4 8.5 8 11 4.6-2.5 8-6 8-11V5l-8-3Z" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round"/></svg>
      <span>Kavach</span>
    </a>
    <div class="nav-r">
      <div class="nav-l">
        <a href="#numbers" class="sm">Results</a>
        <a href="#explorer" class="sm">Explorer</a>
        <a href="#method">Method</a>
        <a href="#limits" class="sm">Limits</a>
      </div>
      <a class="btn sm" href="{{ repo }}" aria-label="View on GitHub">
        <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 .5A11.5 11.5 0 0 0 .5 12a11.5 11.5 0 0 0 7.86 10.92c.58.1.79-.25.79-.56 0-.28-.01-1.02-.02-2-3.19.69-3.87-1.54-3.87-1.54-.52-1.33-1.28-1.68-1.28-1.68-1.05-.72.08-.7.08-.7 1.16.08 1.77 1.19 1.77 1.19 1.03 1.77 2.7 1.26 3.36.96.1-.75.4-1.26.73-1.55-2.55-.29-5.23-1.28-5.23-5.69 0-1.26.45-2.28 1.19-3.09-.12-.29-.52-1.46.11-3.05 0 0 .97-.31 3.18 1.18a11 11 0 0 1 5.79 0c2.2-1.49 3.17-1.18 3.17-1.18.63 1.59.23 2.76.11 3.05.74.81 1.19 1.83 1.19 3.09 0 4.42-2.69 5.4-5.25 5.68.41.36.78 1.06.78 2.14 0 1.55-.01 2.8-.01 3.18 0 .31.21.67.8.56A11.5 11.5 0 0 0 23.5 12 11.5 11.5 0 0 0 12 .5Z"/></svg>
        <span class="btn-t">GitHub</span>
      </a>
    </div>
  </div>
</nav>

<header>
  <div class="wrap">
    <span class="pill"><i></i>Independent benchmark · Phase 2 · {{ detector_count }} detectors</span>
    <h1>Every one of these is a normal message. Your guardrail calls them <i>attacks.</i></h1>
    <p class="sub">We tested {{ detector_count }} prompt-injection detectors on ordinary Tamil–English messages — the way people actually type. <b>ProtectAI, the most accurate of them, flagged {{ pct(phase2_by_id.protectai.benign_tl_rate) }} of them as attacks.</b></p>
    <div class="cta">
      <a class="btn primary" href="{{ repo }}/tree/master/data">View the data<svg viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M5 12h14M13 6l6 6-6 6" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"/></svg></a>
      <a class="btn" href="#method">Read the method</a>
    </div>

    <div class="log">
      <div class="log-bar">
        <span>protectai · deberta-v3-base-v2 · threshold 0.5</span>
        <div class="seg" role="group" aria-label="Message language">
          <button data-lang="en" aria-pressed="true">English</button>
          <button data-lang="ta" aria-pressed="false">Tanglish</button>
        </div>
      </div>
      <div id="rows"></div>
      <div class="log-foot">// {{ log_en|length }} real benign prompts from data/benign.jsonl + data/benign_tanglish.jsonl, scored by results/raw.jsonl — 5 flip from allowed to blocked, 2 stay allowed in both languages</div>
    </div>
  </div>
</header>

{% set pa = phase2_by_id.protectai %}
<div class="wrap">
  <div class="strip">
    <div class="stat reveal">
      <div class="stat-top"><div class="k">Benign blocked · English</div></div>
      <div class="v">{{ pct(pa.benign_en_rate) }}</div>
      <div class="meter"><i data-w="{{ (pa.benign_en_rate*100)|round(1) }}"></i></div>
      <p class="c">ProtectAI already flags nearly half of harmless prompts.</p>
    </div>
    <div class="stat reveal">
      <div class="stat-top"><div class="k">Benign blocked · Tanglish</div><span class="chip bad">+{{ "%.1f"|format(pa.benign_delta*100) }} pts</span></div>
      <div class="v bad">{{ pct(pa.benign_tl_rate) }}</div>
      <div class="meter bad"><i data-w="{{ (pa.benign_tl_rate*100)|round(1) }}"></i><b style="left:{{ (pa.benign_en_rate*100)|round(1) }}%"></b></div>
      <p class="c">Five of six ordinary bilingual messages, refused. The tick marks the English rate.</p>
    </div>
    <div class="stat reveal">
      <div class="stat-top"><div class="k">Attacks caught · Tanglish</div><span class="chip ok">unchanged</span></div>
      <div class="v">{{ pct(pa.attack_tl_rate) }}</div>
      <div class="meter"><i data-w="{{ (pa.attack_tl_rate*100)|round(1) }}"></i><b style="left:{{ (pa.attack_en_rate*100)|round(1) }}%"></b></div>
      <p class="c">{{ pct(pa.attack_en_rate) }} in English — code-switching is no evasion route.</p>
    </div>
  </div>
</div>

<section id="numbers">
  <div class="wrap reveal">
    <div class="kicker"><b>01</b> / Results</div>
    <div class="sec-head">
      <h2>All three detectors, English vs. Tanglish</h2>
      <span class="tag">95% Wilson CI</span>
    </div>
    <div class="tbl">
      <table>
        <thead>
          <tr>
            <th>Detector</th>
            <th>Attacks caught<br>English</th>
            <th>Attacks caught<br>Tanglish</th>
            <th>Δ</th>
            <th>Benign blocked<br>English</th>
            <th>Benign blocked<br>Tanglish</th>
            <th>Δ</th>
          </tr>
        </thead>
        <tbody>
          {% for d in phase2 %}
          <tr>
            <td class="d">{{ d.label }}</td>
            <td class="{{ d.attack_value_class }}">{{ pct(d.attack_en_rate) }}<span class="ci">{{ ci_str(d.attack_en_ci) }}</span></td>
            <td class="{{ d.attack_value_class }}">{{ pct(d.attack_tl_rate) }}<span class="ci">{{ ci_str(d.attack_tl_ci) }}</span></td>
            <td class="{{ d.attack_delta_class }}">{{ "%+.1f" | format(d.attack_delta * 100) }}</td>
            <td class="{{ d.benign_en_class }}">{{ pct(d.benign_en_rate) }}<span class="ci">{{ ci_str(d.benign_en_ci) }}</span></td>
            <td class="{{ d.benign_tl_class }}">{{ pct(d.benign_tl_rate) }}<span class="ci">{{ ci_str(d.benign_tl_ci) }}</span></td>
            <td class="{{ d.benign_delta_class }}">{{ "%+.1f" | format(d.benign_delta * 100) }}</td>
          </tr>
          {% endfor %}
        </tbody>
      </table>
      <div class="tbl-foot">// all cells computed from results/raw.jsonl at commit {{ commit }} — n=299 attacks, n=150 benign, matched-pair by en_source_id. Llama Guard is a content-safety classifier, not a prompt-injection detector — see "What this means" below.</div>
    </div>
  </div>
</section>

<section id="explorer">
  <div class="wrap reveal">
    <div class="kicker"><b>02</b> / Explorer</div>
    <div class="sec-head">
      <h2>Browse every payload</h2>
      <span class="tag">precomputed · no inference</span>
    </div>
    <p class="sec-sub">Every matched pair we fired at the detectors — {{ n_explorer_attack }} attacks and {{ n_explorer_benign }} benign prompts — with each detector's real verdict and score. Toggle a payload between English and Tanglish and watch the verdicts move. Opens on the finding: benign prompts that flip to blocked.</p>

    <div class="xp-bar">
      <div class="xp-f">
        <span class="xp-f-lab">Type</span>
        <div class="seg" data-filter="kind">
          <button data-v="benign" aria-pressed="true">Benign</button>
          <button data-v="attack" aria-pressed="false">Attack</button>
          <button data-v="all" aria-pressed="false">All</button>
        </div>
      </div>
      <div class="xp-f">
        <span class="xp-f-lab">Status</span>
        <div class="seg" data-filter="status">
          <button data-v="flip" aria-pressed="true">Flipped</button>
          <button data-v="same" aria-pressed="false">Unchanged</button>
          <button data-v="all" aria-pressed="false">All</button>
        </div>
      </div>
      <div class="xp-f">
        <span class="xp-f-lab">Detector</span>
        <div class="seg" data-filter="detector">
          <button data-v="all" aria-pressed="true">All</button>
          <button data-v="protectai" aria-pressed="false">ProtectAI</button>
          <button data-v="prompt_guard" aria-pressed="false">Prompt Guard</button>
          <button data-v="llama_guard" aria-pressed="false">Llama Guard</button>
        </div>
      </div>
      <div class="xp-count" id="xpCount"></div>
    </div>

    <div class="xp-main">
      <div class="xp-list" id="xpList" role="listbox" aria-label="Payloads"></div>
      <div class="xp-detail" id="xpDetail"></div>
    </div>
    <div class="tbl-foot" style="border:0;padding-left:0">// browsing {{ explorer_data_file }} — generated from results/raw.jsonl + data/ at commit {{ commit }}. Every verdict and score is the detector's real output; nothing here is recomputed live.</div>
  </div>
</section>

<section id="means">
  <div class="wrap reveal">
    <div class="kicker"><b>03</b> / What this means</div>
    <div class="sec-head"><h2>What this means</h2></div>
    <div class="prose">
      <p>We went looking for a security hole — attacks slipping past guardrails when written in Tanglish. <strong>We didn't find one.</strong> ProtectAI's detection held flat at {{ pct(phase2_by_id.protectai.attack_en_rate) }} → {{ pct(phase2_by_id.protectai.attack_tl_rate) }}, and we're reporting that rather than burying it.</p>

      <p class="pull">The failure isn't that attackers get in. It's that ordinary people get shut out.</p>

      <p><strong>ProtectAI</strong> is the headline result: over-defense nearly doubles, {{ pct(phase2_by_id.protectai.benign_en_rate) }} → {{ pct(phase2_by_id.protectai.benign_tl_rate) }}, a {{ "%.1f"|format(phase2_by_id.protectai.benign_delta * 100) }}pt jump with non-overlapping confidence intervals. In Tanglish it starts flagging benign prompts almost as often as it flags English attacks.</p>
      <p><strong>Prompt Guard</strong> moves down on both axes ({{ "%.1f"|format(phase2_by_id.prompt_guard.attack_delta * 100) }}pt detection, {{ "%.1f"|format(phase2_by_id.prompt_guard.benign_delta * 100) }}pt over-defense). It doesn't get more selective in Tanglish — it gets noisier in the direction of flagging less overall, consistent with Phase 1: it wasn't discriminating attack from benign so much as reacting to surface features that Tanglish disrupts.</p>
      <p><strong>Llama Guard</strong> stays flat at zero on both axes in both languages — not a Tanglish-specific failure. It's a content-safety classifier (violence, hate, self-harm), not a prompt-injection detector, so there's no signal to lose in either language.</p>
    </div>
  </div>
</section>

<section id="method">
  <div class="wrap reveal">
    <div class="kicker"><b>04</b> / Method</div>
    <div class="sec-head"><h2>Method</h2></div>
    <div class="spec">
      <div class="spec-row">
        <div class="spec-term">Attack set</div>
        <div class="spec-def">300 prompts sampled from <a href="https://tensortrust.ai">Tensor Trust</a> (<code>hijacking-robustness/v1</code>, Toyer et al., ICLR 2024), tagged <code>attack_type: prompt_hijacking</code>. 299 of 300 got a Tanglish counterpart; the one exclusion is a pure repeated-symbol flood with no natural-language content to code-switch.</div>
      </div>
      <div class="spec-row">
        <div class="spec-term">Benign set</div>
        <div class="spec-def">300 prompts from NotInject/InjecGuard: benign inputs deliberately containing trigger words (e.g. "ignore", emoji, imperative phrasing) that naive keyword defenses tend to over-flag. 150 of 300 were sampled for Tanglish (fixed seed 42, stratified by category).</div>
      </div>
      <div class="spec-row">
        <div class="spec-term">Tanglish generation</div>
        <div class="spec-def">Both Tanglish sets render the English source into natural, Roman-script Tamil-English code-switched prose, not word-for-word translation. Operative content was preserved byte-for-byte rather than translated: quoted target-output strings, special tokens, binary/base64 blobs, and non-English attacker text for attacks; the NotInject trigger words themselves for benign prompts, since translating those away would break the over-defense measurement.</div>
      </div>
      <div class="spec-row">
        <div class="spec-term">Matched-pair design</div>
        <div class="spec-def">Every Tanglish row carries an <code>en_source_id</code> back to its English counterpart. English-vs-Tanglish rates are always computed on the same underlying payloads, never against the full 300/300 Phase 1 sets — mixing those would introduce a composition confound.</div>
      </div>
      <div class="spec-row">
        <div class="spec-term">Scoring</div>
        <div class="spec-def">All three detectors use the same flag threshold (score &gt; 0.5) and adapter interface (<code>predict(text) -&gt; {"flagged": bool, "score": float}</code>). Prompt Guard's score sums its INJECTION + JAILBREAK probabilities; ProtectAI is a two-label (BENIGN/INJECTION) model with no jailbreak training; Llama Guard's score is its own <code>unsafe</code> token probability normalized against <code>safe</code>.</div>
      </div>
      <div class="spec-row">
        <div class="spec-term">Verification</div>
        <div class="spec-def">All 23 attack flips (caught in English, missed in Tanglish, all Prompt Guard) were read side-by-side against their English source; all preserve meaning and operative payload content. That pass also caught 27 rows with stray native-script/homoglyph characters substituted for Latin letters, since fixed and re-scored. The 69 benign flips (9 Prompt Guard flagged-in-English-not-Tanglish, 60 ProtectAI flagged-in-Tanglish-not-English) are validated automatically (schema, no-op sweep, trigger-word preservation, Roman-script) but not manually re-read for translation fidelity.</div>
      </div>
      <div class="spec-row">
        <div class="spec-term">Reproducibility</div>
        <div class="spec-def">Every number on this page is recomputed from <code>results/raw.jsonl</code> and the flip files at build time — regenerate with <code>python build_site.py</code> after any re-score.</div>
      </div>
    </div>
  </div>
</section>

<section id="limits">
  <div class="wrap reveal">
    <div class="kicker"><b>05</b> / Limits</div>
    <div class="sec-head"><h2>Limits</h2></div>
    <div class="spec">
      <div class="spec-row">
        <div class="spec-term">Review coverage</div>
        <div class="spec-def">All 23 attack flips got a side-by-side human read; the 69 benign flips are validated only automatically, not manually re-read for meaning drift.</div>
      </div>
      <div class="spec-row">
        <div class="spec-term">What's measured</div>
        <div class="spec-def">What's verified is that Tanglish payloads preserve the meaning and operative content of their English source — not whether either version actually succeeds as an attack against a live target LLM. This benchmark measures whether detectors flag the text, not whether the underlying hijack would work if it reached a model.</div>
      </div>
      <div class="spec-row">
        <div class="spec-term">Scope</div>
        <div class="spec-def">This finding is about Tamil-English code-switching specifically, not code-switching as a category. Hinglish, Kanglish, Telglish, or other language pairs may behave differently and would need their own corpora and runs.</div>
      </div>
    </div>
  </div>
</section>

<footer>
  <div class="wrap">
    <div class="foot-cols">
      <div class="foot-brand">
        <span class="brand">
          <svg viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M12 2 4 5v6c0 5 3.4 8.5 8 11 4.6-2.5 8-6 8-11V5l-8-3Z" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round"/></svg>
          <span>Kavach</span>
        </span>
        <p class="foot-tag">An independent, reproducible robustness benchmark for LLM safety guardrails. Defensive research — we measure how well existing defenses catch attacks.</p>
      </div>
      <div class="foot-col">
        <h4>Benchmark</h4>
        <a href="#numbers">Results</a>
        <a href="#explorer">Explorer</a>
        <a href="#method">Method</a>
        <a href="#limits">Limits</a>
      </div>
      <div class="foot-col">
        <h4>Data sources</h4>
        <a href="https://tensortrust.ai">Tensor Trust</a>
        <a href="{{ repo }}/blob/master/data/build_benign.py">NotInject benign</a>
        <a href="{{ repo }}/tree/master/data">Full corpus</a>
      </div>
      <div class="foot-col">
        <h4>Project</h4>
        <a href="{{ repo }}">GitHub</a>
        <a href="{{ repo }}/blob/master/results/raw.jsonl">Raw results</a>
        <a href="{{ repo }}#readme">Cite</a>
      </div>
    </div>
    <div class="foot-bot">
      <span>Independent · defensive research · no affiliation with the evaluated vendors</span>
      <span>Built from commit {{ commit }}</span>
    </div>
  </div>
</footer>

<script>
  window.KAVACH_LOG = { en: {{ log_en | tojson }}, ta: {{ log_ta | tojson }} };
</script>
<script src="{{ explorer_data_file }}"></script>
<script>
{% raw %}
(function(){
  var reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  /* ---- segmented control: sliding indicator ---- */
  function initSeg(seg){
    if(seg.__init) return;
    var ind = document.createElement('span');
    ind.className = 'seg-ind';
    seg.insertBefore(ind, seg.firstChild);
    seg.classList.add('seg--js');
    seg.__place = function(){
      var a = seg.querySelector('button[aria-pressed="true"]');
      if(!a){ ind.style.width = '0'; return; }
      ind.style.width = a.offsetWidth + 'px';
      ind.style.left = a.offsetLeft + 'px';
    };
    seg.__init = true;
    requestAnimationFrame(seg.__place);
  }
  function setActive(seg, btn){
    seg.querySelectorAll('button').forEach(function(b){ b.setAttribute('aria-pressed', b === btn ? 'true' : 'false'); });
    if(seg.__place) seg.__place();
  }
  var segs = [];
  document.querySelectorAll('.seg').forEach(function(s){ initSeg(s); segs.push(s); });
  window.addEventListener('resize', function(){ segs.forEach(function(s){ if(s.__place) s.__place(); }); });

  /* ---- hero message log ---- */
  (function(){
    var data = window.KAVACH_LOG, host = document.getElementById('rows');
    var seg = document.querySelector('.log-bar .seg');
    if(!data || !host || !seg) return;
    var AV = '<svg viewBox="0 0 24 24" fill="none" aria-hidden="true"><circle cx="12" cy="8.2" r="3.3" stroke="currentColor" stroke-width="1.6"/><path d="M5.7 19c.5-3.1 3-5 6.3-5s5.8 1.9 6.3 5" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/></svg>';
    var OK = '<svg viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M5 12.5l4.2 4L19 6.5" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"/></svg>';
    var NO = '<svg viewBox="0 0 24 24" fill="none" aria-hidden="true"><circle cx="12" cy="12" r="8.4" stroke="currentColor" stroke-width="2"/><path d="M6.6 6.6l10.8 10.8" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>';
    function render(k){
      host.innerHTML = data[k].map(function(r){
        var v = r.verdict === 'block' ? NO + 'BLOCKED' : OK + 'ALLOWED';
        return '<div class="msg" data-v="' + r.verdict + '"><div class="msg-av">' + AV + '</div><div class="msg-body"><div class="msg-bubble"></div><span class="verdict">' + v + '</span></div></div>';
      }).join('');
      var b = host.querySelectorAll('.msg-bubble');
      data[k].forEach(function(r, i){ b[i].textContent = r.text; });
    }
    seg.querySelectorAll('button').forEach(function(b){
      b.addEventListener('click', function(){ setActive(seg, b); render(b.dataset.lang); });
    });
    render('en');
  })();

  /* ---- reveal on scroll (+ animate any meters inside) ---- */
  (function(){
    var els = document.querySelectorAll('.reveal');
    function fill(el){ el.querySelectorAll('.meter > i[data-w]').forEach(function(i){ i.style.width = i.getAttribute('data-w') + '%'; }); }
    if(reduce || !('IntersectionObserver' in window)){
      els.forEach(function(e){ e.classList.add('in'); fill(e); });
      return;
    }
    var io = new IntersectionObserver(function(ents){
      ents.forEach(function(en){
        if(en.isIntersecting){ en.target.classList.add('in'); fill(en.target); io.unobserve(en.target); }
      });
    }, { rootMargin: '0px 0px -8% 0px', threshold: 0.08 });
    els.forEach(function(e){ io.observe(e); });
  })();

  /* ---- explorer ---- */
  (function(){
    var DATA = window.KAVACH_EXPLORER;
    var listEl = document.getElementById('xpList');
    if(!DATA || !listEl) return;
    var detailEl = document.getElementById('xpDetail');
    var countEl = document.getElementById('xpCount');
    var dets = DATA.detectors;
    var payloads = DATA.payloads;
    var state = { kind: 'benign', status: 'flip', detector: 'all', lang: 'en', sel: null };

    function flips(p, det){ return p.en[det].flagged !== p.ta[det].flagged; }
    function anyFlip(p){ return dets.some(function(d){ return flips(p, d.id); }); }
    function isFlipped(p){ return state.detector === 'all' ? anyFlip(p) : flips(p, state.detector); }
    function verdict(p, det){ return p[state.lang][det]; }
    function snippet(p){ return (state.lang === 'en' ? p.en_text : p.ta_text).replace(/\s+/g, ' ').trim(); }

    function filtered(){
      return payloads.filter(function(p){
        if(state.kind !== 'all' && p.kind !== state.kind) return false;
        if(state.status === 'flip' && !isFlipped(p)) return false;
        if(state.status === 'same' && isFlipped(p)) return false;
        return true;
      });
    }

    function animMeters(scope){
      scope.querySelectorAll('.meter > i[data-w]').forEach(function(f){
        f.style.width = '0';
        requestAnimationFrame(function(){ requestAnimationFrame(function(){ f.style.width = f.getAttribute('data-w') + '%'; }); });
      });
    }

    function meterHTML(v){
      var w = Math.max(0, Math.min(100, v.score * 100)).toFixed(1);
      return '<div class="meter' + (v.flagged ? ' bad' : '') + '"><i data-w="' + w + '"></i><s class="thr"></s></div>';
    }

    function renderDetail(p){
      if(!p){ detailEl.innerHTML = ''; return; }
      var langSeg = '<div class="seg" data-role="lang"><button data-lang="en" aria-pressed="' + (state.lang === 'en' ? 'true' : 'false') + '">English</button><button data-lang="ta" aria-pressed="' + (state.lang === 'ta' ? 'true' : 'false') + '">Tanglish</button></div>';
      var meta = '<span class="badge ' + p.kind + '">' + p.kind + '</span>' + (p.tag ? '<span class="xp-d-id">' + p.tag + '</span>' : '') + '<span class="xp-d-id">' + (state.lang === 'en' ? p.id : p.tid) + '</span>';
      var verdicts = dets.map(function(d){
        var v = verdict(p, d.id);
        var stamp = v.flagged ? '<span class="stamp block">BLOCKED</span>' : '<span class="stamp allow">ALLOWED</span>';
        var fl = flips(p, d.id) ? '<span class="xp-v-flip">flips EN⇄TA</span>' : '';
        return '<div class="xp-v"><div class="xp-v-head"><span class="xp-v-name">' + d.label + '</span>' + stamp + fl + '<span class="xp-v-score">' + v.score.toFixed(4) + '</span></div><div class="xp-v-meter">' + meterHTML(v) + '</div></div>';
      }).join('');
      detailEl.innerHTML = '<div class="xp-d-top"><div class="xp-d-meta">' + meta + '</div>' + langSeg + '</div><div class="xp-d-text"></div><div class="xp-verdicts">' + verdicts + '</div>';
      detailEl.querySelector('.xp-d-text').textContent = (state.lang === 'en' ? p.en_text : p.ta_text);
      var lseg = detailEl.querySelector('.seg[data-role="lang"]');
      initSeg(lseg);
      lseg.querySelectorAll('button').forEach(function(b){
        b.addEventListener('click', function(){ state.lang = b.dataset.lang; setActive(lseg, b); renderList(); });
      });
      animMeters(detailEl);
    }

    function select(id){
      state.sel = id;
      listEl.querySelectorAll('.xp-item').forEach(function(it){ it.classList.toggle('sel', it.getAttribute('data-id') === id); });
      renderDetail(payloads.find(function(p){ return p.id === id; }));
    }

    function renderList(){
      var rows = filtered();
      countEl.innerHTML = 'Showing <b>' + rows.length + '</b> of ' + payloads.length + ' pairs';
      if(!rows.length){ listEl.innerHTML = '<div class="xp-empty">No payloads match these filters.</div>'; renderDetail(null); return; }
      var selId = rows.some(function(p){ return p.id === state.sel; }) ? state.sel : rows[0].id;
      listEl.innerHTML = rows.map(function(p){
        var dots = dets.map(function(d){
          var mute = (state.detector !== 'all' && d.id !== state.detector) ? ' mute' : '';
          return '<span class="dot ' + (verdict(p, d.id).flagged ? 'block' : 'allow') + mute + '" title="' + d.label + ': ' + (verdict(p, d.id).flagged ? 'blocked' : 'allowed') + '"></span>';
        }).join('');
        var fl = isFlipped(p) ? '<span class="xp-flip">⇄</span>' : '<span></span>';
        return '<div class="xp-item' + (p.id === selId ? ' sel' : '') + '" role="option" tabindex="0" data-id="' + p.id + '"><span class="xp-dots">' + dots + '</span><span class="xp-snip"></span>' + fl + '</div>';
      }).join('');
      var items = listEl.querySelectorAll('.xp-item');
      rows.forEach(function(p, i){ items[i].querySelector('.xp-snip').textContent = snippet(p); });
      select(selId);
    }

    document.querySelectorAll('.xp-bar .seg[data-filter]').forEach(function(seg){
      var key = seg.dataset.filter;
      seg.querySelectorAll('button').forEach(function(b){
        b.addEventListener('click', function(){ state[key] = b.dataset.v; setActive(seg, b); renderList(); });
      });
    });
    listEl.addEventListener('click', function(e){
      var it = e.target.closest('.xp-item'); if(it) select(it.getAttribute('data-id'));
    });
    listEl.addEventListener('keydown', function(e){
      if(e.key === 'Enter' || e.key === ' '){ var it = e.target.closest('.xp-item'); if(it){ e.preventDefault(); select(it.getAttribute('data-id')); } }
    });

    renderList();
  })();
})();
{% endraw %}
</script>
</body>
</html>
